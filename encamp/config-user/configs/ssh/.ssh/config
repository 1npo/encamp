Host *
  ControlMaster auto
  ControlPath ~/.ssh/sockets/%r@%h-%p
  ControlPersist 600
  AddKeysToAgent yes

Host globule
  HostName globule
  Port 22
  User nick
  IdentityFile /home/nick/.ssh/id_rsa-globule

Host diatom
  HostName diatom
  Port 22
  User nick 
  IdentityFile /home/nick/.ssh/id_rsa-diatom

